    "lucide-react": "^0.460.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.5.5",
    "webtorrent": "^2.5.10"
  },
  "devDependencies": {
