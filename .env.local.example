# ── AniList ────────────────────────────────────────────────
# No key required — public GraphQL API.
NEXT_PUBLIC_ANILIST_ENDPOINT=https://graphql.anilist.co

# ── Supabase (watchlist / history / progress) ──────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Clerk (auth) ───────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Stripe (Pro tier — £0.99/mo) ───────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ── Stream source resolution ───────────────────────────────
NEXT_PUBLIC_TORRENTIO_BASE=https://torrentio.strem.fun
NEXT_PUBLIC_ANIZIP_BASE=https://api.ani.zip
NEXT_PUBLIC_NYAA_BASE=https://nyaa.si

# Real-Debrid — direct HTTPS streams for SUB (cached torrents). Get a key at
# https://real-debrid.com/apitoken  (server-only secret — never exposed).
REALDEBRID_API_KEY=

# Streaming provider (HiAnime via embedded `aniwatch` scraper) — when enabled,
# this is the PRIMARY source: pre-transcoded HLS with native English Sub AND
# Dub, plus real English subtitles. No mkv transcoding, no RD evictions.
# Real-Debrid remains the silent fallback if HiAnime is unreachable or its
# scraper has broken — the site keeps working either way.
#
# EXPERIMENTAL: The scraper depends on HiAnime's HTML, which changes; the
# `aniwatch` GitHub repo has been DMCA-takedown'd (npm package still installs).
# Set to "true" to opt in.
ENABLE_HIANIME=

# ── Trailers (optional) ────────────────────────────────────
# YouTube Data API v3 key — when set, anime detail pages show an English-
# preferred trailer (searched on YouTube) instead of AniList's JP-only PV.
# Get one at https://console.cloud.google.com (enable "YouTube Data API v3").
YOUTUBE_API_KEY=

# ── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
